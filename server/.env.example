# Server
PORT=3001

# JWT Secret (generate a random string, e.g.: openssl rand -hex 32)
JWT_SECRET=your-jwt-secret-change-this

# App URL (use ngrok URL for dev, real domain for production)
APP_URL=http://localhost:5173

# Google OAuth (https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth (https://github.com/settings/developers)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Merriam-Webster Collegiate (fallback for audio/phonetic)
MW_API_KEY=your-mw-collegiate-key

# MW Intermediate Dictionary (Grades 6–8) — simpler definitions
# Same registration at dictionaryapi.com, "Intermediate Dictionary" key
MW_INTERMEDIATE_API_KEY=your-mw-intermediate-key

# MW Learner's Dictionary (simpler definitions for ESL, optional)
MW_LEARNER_API_KEY=your-mw-learner-key

# Discovery: GPT for simplifying articles (IELTS 6 level)
OPENAI_API_KEY=your-openai-key

# Daily crawl cron (optional)
# CRON_SCHEDULE=0 0 * * *     # Midnight UTC (default)
# CRON_SCHEDULE=0 5 * * *     # 5am UTC = midnight Eastern
# VOCAB_CRON_SCHEDULE=0 1 * * *   # Vocab story generation 1am UTC (default)
# CRON_SECRET=your-cron-secret   # Required for POST /api/cron/* (daily-crawl, generate-vocab-stories, etc.)

# Admin dashboard (monitoring)
# ADMIN_SECRET=your-admin-secret   # Required for GET /api/admin/* (metrics, reports, dashboard)
