PORT=3001
NODE_ENV=production
APP_URL=https://feedlingo.example.com
DATABASE_PATH=/data/data.db
SCHEDULER_ENABLED=true
CRON_TIMEZONE=America/Los_Angeles
CRON_SCHEDULE=0 7 * * *
